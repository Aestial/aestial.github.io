html {
    height: 100%;
}

body {
    margin: 0;
    padding: 0;
    overflow: hidden; /* setting overflow is nice */
    background: #fff; /* DO set a background color! */
    min-height: 100%;
    cursor: pointer;
}

.image {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #ffdb0f;
    background: linear-gradient(to bottom, #ffdb0f, #fff4a4);
    background: -moz-linear-gradient(to bottom, #ffdb0f, #fff4a4);
    background: -webkit-linear-gradient(to bottom, #ffdb0f, #fff4a4);
}

.cta {
    position: absolute;
    box-shadow: 0 0 20px rgba(0, 0, 0, .3);
    border-radius: 70px;
    top: 50%;
    left: 50%;
    right: 100%;
    width: 70px;
    height: 70px;
    margin: 0;
    padding: 0;
    background: url('cta.png') 0 0 no-repeat;
    transform: translate3d(-50%, -50%, 0);
    -moz-transform: translate3d(-50%, -50%, 0);
    -webkit-transform: translate3d(-50%, -50%, 0);
}

.cta:hover {
    background-position: 0 -70px;
}

