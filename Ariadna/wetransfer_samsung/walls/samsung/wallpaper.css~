/* this stuff is needed to make sure the video will fill screen */
.video-container {
    position: fixed;
    z-index: 0;
    min-width: 100%;
    min-height: 100%;
    transition: opacity .5s ease-out;
    -ms-transition: opacity .5s ease-out;
    -moz-transition: opacity .5s ease-out;
    -webkit-transition: opacity .5s ease-out;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    top: 0px;
    left: 0px;
    -webkit-backface-visibility: hidden;
}

.embed-container {
    position: absolute;
    z-index: 0;
    width: 100%;
    height: 100%;
    top: 0px;
    left: 0px;
    margin: 0;
    overflow: hidden;
}