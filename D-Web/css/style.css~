@font-face {
    font-family: Thunderman;
    src: url(../fonts/Thunderman.ttf);
    font-weight: bold;
}

@font-face {
    font-family: Bubblegum;
    src: url(../fonts/Bubblegum.ttf);
    font-weight: bold;
}

@font-face {
    font-family: Grobold;
    src: url(../fonts/GROBOLD.ttf);
    font-weight: bold;
}


*{ box-sizing: border-box; margin: 0; padding: 0 }

body {
    color: #000000f;
    font-family: tahoma;
    font-size:15px;
    background-color: rgb(255,229,237);
    background-image: -o-linear-gradient(bottom, rgb(255,229,237) 0%, rgb(224,255,233) 100%);
    background-image: -moz-linear-gradient(bottom, rgb(255,229,237) 0%, rgb(224,255,233) 100%);
    background-image: -webkit-linear-gradient(bottom, rgb(255,229,237) 0%, rgb(224,255,255) 100%);
    background-image: -ms-linear-gradient(bottom, rgb(255,229,237) 0%, rgb(224,255,233) 100%);
    background-image: linear-gradient(bottom, rgb(255,229,237) 0%, rgb(224,255,233) 100%);
    margin: 0px;
    overflow: hidden;
    width : 100%;
    height: 100%;
}

p {
    font-family: Thunderman, Helvetica, Arial, sans-serif;
    position: absolute; left: 10px; top: 10px; line-height: 1.6em;
    opacity: 0.04;
}

p:hover{ opacity: 0.55 }

a{ color: black; text-shadow: 0 1px 0 rgba( 0,0,0,.5 ) }

div#container{
    position: absolute;
}